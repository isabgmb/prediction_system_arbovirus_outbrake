# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# Database
# SQLite — local testing, no Docker needed
DATABASE_URL=sqlite+aiosqlite:///./data/sipsa_test.db

# PostgreSQL — uncomment for production
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sipsa

# Auth
SECRET_KEY=change-this-to-a-random-string-in-production

# Model
MODEL_WEIGHTS_PATH=data/models/eval_results.npz
